-    private static float GetResourceBaseWeight(BaseResourceType resourceType)
-    {
-        return resourceType switch
-        {
-            BaseResourceType.Wood => 1.0f,
-            BaseResourceType.Stone => 1.1f,
-            BaseResourceType.Metal => 1.3f,
-            _ => 0.0f
