+	public void ApplyProfile(MercenaryProfile profile)
+	{
+		Profile = profile;
+		MercenaryName = string.IsNullOrWhiteSpace(profile.DisplayName)
+			? MercenaryName
+			: profile.DisplayName;
+		RefreshInventoryCapacity();
+
+		if (Profile.Condition.Health <= 0)
+		{
+			Profile.Condition.Health = Profile.Stats.MaxHealth;
+		}
+
+		UpdateNameLabel();
+	}
