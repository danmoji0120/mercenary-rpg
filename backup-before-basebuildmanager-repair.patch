+	private static IEnumerable<Vector2I> GetObjectCells(Vector2I originCell, Vector2I size)
+	{
+		for (int y = 0; y < size.Y; y++)
+		{
+			for (int x = 0; x < size.X; x++)
+			{
+				yield return originCell + new Vector2I(x, y);
+			}
+		}
+	}
