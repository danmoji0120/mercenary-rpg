+	public void Initialize(string mercenaryName, Vector2 spawnPosition, float moveSpeed, MercenaryProfile? profile)
+	{
+		MercenaryProfile effectiveProfile = profile ?? MercenaryProfileProvider.CreateFallbackProfile();
+
+		if (profile == null)
+		{
+			effectiveProfile.DisplayName = mercenaryName;
+		}
+
+		ApplyProfile(effectiveProfile);
+		MercenaryName = effectiveProfile.DisplayName;
+		GlobalPosition = spawnPosition;
+		MoveSpeed = moveSpeed * Mathf.Max(0.25f, Profile.Stats.MoveSpeedMultiplier);
+		ControlMode = MercenaryControlMode.Life;
+		OrderState = MercenaryOrderState.None;
+
+		UpdateNameLabel();
+	}
