+        int mood = Mathf.RoundToInt(condition.Mood);
+        int stress = Mathf.RoundToInt(condition.Stress);
+        int hygiene = Mathf.RoundToInt(condition.Hygiene);
+        int injurySeverity = Mathf.RoundToInt(condition.InjurySeverity);
