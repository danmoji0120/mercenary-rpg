+	public void ValidateLogisticsState(bool verboseLogs)
+	{
+		List<string> warnings = new();
+
+		RefreshInventoryCapacity();
+
+		if (!Inventory.Validate(out string inventoryWarning))
+		{
+			warnings.Add(inventoryWarning);
+		}
+
+		if (_lifeAI != null)
+		{
+			string lifeWarning = _lifeAI.ValidateLogisticsState(this, verboseLogs);
+
+			if (!string.IsNullOrWhiteSpace(lifeWarning))
+			{
+				warnings.Add(lifeWarning);
+			}
+		}
+
+		string nextWarning = string.Join(" / ", warnings);
+
+		if (!string.IsNullOrWhiteSpace(nextWarning)
+			&& (verboseLogs || nextWarning != _logisticsValidationWarning))
+		{
+			GD.PushWarning($"Logistics validation warning for {MercenaryName}: {nextWarning}");
+		}
+
+		_logisticsValidationWarning = nextWarning;
+	}
